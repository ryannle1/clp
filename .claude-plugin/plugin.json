{
  "name": "clp",
  "version": "1.0.0",
  "description": "Context Lifecycle Protocol — Zone-based context management with budget tracking, structured handoffs, and demand-loaded skills for Claude Code.",
  "author": "CLP Contributors",
  "skills": [
    "skills/clp-status",
    "skills/clp-checkpoint",
    "skills/clp-handoff",
    "skills/clp-doctor",
    "skills/clp-plan",
    "skills/clp-reset",
    "skills/clp-setup"
  ],
  "hooks": {
    "SessionStart": [
      { "matcher": "", "hooks": [{ "type": "command", "command": "bash $PLUGIN_DIR/hooks/clp-session-start.sh" }] }
    ],
    "UserPromptSubmit": [
      { "matcher": "", "hooks": [{ "type": "command", "command": "bash $PLUGIN_DIR/hooks/clp-prompt-scan.sh" }] }
    ],
    "PreCompact": [
      { "matcher": "", "hooks": [{ "type": "command", "command": "bash $PLUGIN_DIR/hooks/clp-pre-compact.sh" }] }
    ],
    "SessionEnd": [
      { "matcher": "", "hooks": [{ "type": "command", "command": "bash $PLUGIN_DIR/hooks/clp-session-end.sh" }] }
    ]
  },
  "rules": [
    "rules/clp-context-rules.md"
  ]
}
